<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<ScrollPane prefWidth="1400.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.eksamensprojekt.controllers.OmSamlingenController">

    <content>
        <VBox prefWidth="1400.0" style="-fx-background-color: #dddddd;">

            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>

            <!-- HEADER -->
            <HBox prefHeight="120">
                <VBox prefWidth="500">
                    <Label text="KUNSTHAL HOLMEN">
                        <font><Font name="System Bold" size="28"/></font>
                    </Label>
                    <Label text="SADAO WATANABE">
                        <font><Font name="Georgia" size="28"/></font>
                    </Label>
                </VBox>

                <VBox prefWidth="850">
                    <HBox alignment="TOP_RIGHT" spacing="8">
                        <Button text="WATANABE SAMLINGEN" onMouseClicked="#watanabeSamlingenKnap"/>
                        <Button text="FAVORITTER" onMouseClicked="#favoritterKnap"/>
                        <Button text="TEMAER" onMouseClicked="#temaerKnap"/>
                    </HBox>

                    <HBox alignment="TOP_RIGHT" spacing="8">
                        <Button text="UNDERVISNING" onMouseClicked="#undervisningKnap"/>
                        <Button text="OM SAMLINGEN" onMouseClicked="#omSamlingenKnap"/>
                        <Button text="OM OS" onMouseClicked="#omOsKnap"/>
                        <Button text="ADMIN" onMouseClicked="#adminKnap"/>
                    </HBox>
                </VBox>
            </HBox>

            <!-- TITLE -->
            <Label text="Om samlingen" style="-fx-alignment: center;" maxWidth="1400">
                <font><Font name="Georgia" size="34"/></font>
            </Label>

            <!-- MAIN CONTENT -->
            <HBox spacing="60" prefWidth="1300">
                <padding>
                    <Insets top="30" right="40" bottom="30" left="40"/>
                </padding>

                <!-- LEFT TEXT -->
                <VBox prefWidth="600" spacing="20">
                    <Label text="Om Sadao Watanabe">
                        <font><Font name="Georgia" size="30"/></font>
                    </Label>

                    <Label fx:id="watanabeSamlingTekst"
                           wrapText="true"
                           prefWidth="560"
                           text="Watanabe-samlingen er en samling af værker skabt af den japanske kunstner Sadao Watanabe. Værkerne er karakteriseret ved stærke farver, enkle former og bibelske motiver. Hans værker er ofte lavet som træsnit og trykt på særligt japansk papir. Samlingen giver besøgende mulighed for at opleve en særlig forbindelse mellem japansk kunsttradition og kristne fortællinger.">
                        <font><Font size="20"/></font>
                    </Label>
                </VBox>

                <!-- RIGHT IMAGES -->
                <VBox prefWidth="500" spacing="35">
                    <ImageView fx:id="kunsthalHolmenTopBillede"
                               fitWidth="420"
                               fitHeight="280"
                               preserveRatio="true">
                        <image>
                            <Image url="@Billeder/SadaoWatanabe.png"/>
                        </image>
                    </ImageView>

                    <ImageView fx:id="watanabeSamlingBillede"
                               fitWidth="420"
                               fitHeight="360"
                               preserveRatio="true">
                        <image>
                            <Image url="@Billeder/WatanabeKunst.png"/>
                        </image>
                    </ImageView>
                </VBox>
            </HBox>

            <!-- FOOTER -->
            <HBox spacing="180" prefHeight="160">
                <padding>
                    <Insets top="20" right="40" bottom="20" left="40"/>
                </padding>

                <VBox>
                    <Label text="Kunsthal Holmen">
                        <font><Font name="System Bold" size="20"/></font>
                    </Label>
                    <Label text="Østergade 13&#10;DK-6240 Løgumkloster&#10;info@kunsthalholmen.dk"/>
                </VBox>

                <VBox>
                    <Label text="Planlæg dit besøg">
                        <font><Font name="System Bold" size="20"/></font>
                    </Label>
                    <Label text="Åbningstider&#10;Torsdag - Søndag: 13.00 - 17.00&#10;Mandag - Onsdag: lukket"/>
                </VBox>

                <VBox>
                    <Label text="Hold dig opdateret">
                        <font><Font name="System Bold" size="20"/></font>
                    </Label>
                    <Label text="Besøg Kunsthallens hjemmeside"
                           onMouseClicked="#besøgKunsthallensHjemmesideKnap"/>
                </VBox>
            </HBox>

        </VBox>
    </content>
</ScrollPane>